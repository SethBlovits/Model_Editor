{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",                               // debug info
                "/W4",
                "/WX",                               // disable optimization for easier debugging
                "/EHsc",                             // enable C++ exceptions
                "window.c",                  // your source file
                "/I", "C:/EngineV2/Include",           // custom include (d3dx12.h)
                "/I", "C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/ucrt",
                "/I", "C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/um",
                "/I", "C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/shared",
                "/I", "C:/Program Files (x86)/Windows Kits/10/Include/10.0.22621.0/winrt",
                "/Fe:${workspaceFolder}/build/window.exe",
                "/link",
                "User32.lib",
                "d3d12.lib",
                "dxgi.lib",
                "d3dcompiler.lib",
                "dxguid.lib",
                "Shell32.lib",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}